<UserControl x:Class="ThreadPilot.Views.LogViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:ThreadPilot.ViewModels"
             xmlns:local="clr-namespace:ThreadPilot.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=viewmodels:LogViewerViewModel}">

    <UserControl.Resources>
        <Style x:Key="LogLevelTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LogGridViewHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="LogListViewStyle" TargetType="ListView">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="LogEntryStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="Error">
                    <Setter Property="Background" Value="{DynamicResource ErrorBackgroundBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Critical">
                    <Setter Property="Background" Value="{DynamicResource ErrorBackgroundBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Warning">
                    <Setter Property="Background" Value="{DynamicResource WarningBackgroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Standardized Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource LogViewerView_Title}" Style="{StaticResource PageTitleTextStyle}" Margin="0,0,0,4"/>
            <TextBlock Text="{DynamicResource LogViewerView_Subtitle}" Style="{StaticResource PageSubtitleTextStyle}" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Filter and Control Panel -->
        <Border Grid.Row="1" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="16" BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{DynamicResource StandardCardCornerRadius}" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Filters Row 1 -->
                <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{DynamicResource LogViewerView_Search}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Column="3" Text="{DynamicResource LogViewerView_CategoryLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="4" ItemsSource="{Binding AvailableCategories}"
                              SelectedItem="{Binding SelectedCategory}" HorizontalAlignment="Stretch"/>

                    <TextBlock Grid.Column="6" Text="{DynamicResource LogViewerView_LevelLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="7" ItemsSource="{Binding AvailableLogLevels}"
                              SelectedItem="{Binding SelectedLogLevel}" HorizontalAlignment="Stretch"/>
                </Grid>

                <!-- Filters Row 2 -->
                <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{DynamicResource LogViewerView_From}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker Grid.Column="1" SelectedDate="{Binding FromDate}" HorizontalAlignment="Stretch"/>

                    <TextBlock Grid.Column="3" Text="{DynamicResource LogViewerView_To}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker Grid.Column="4" SelectedDate="{Binding ToDate}" HorizontalAlignment="Stretch"/>
                </Grid>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="{DynamicResource LogViewerView_Refresh}" Command="{Binding RefreshLogsCommand}" Margin="5,0">
                        <Button.IsEnabled>
                            <Binding Path="IsLoading">
                                <Binding.Converter>
                                    <local:InverseBooleanConverter/>
                                </Binding.Converter>
                            </Binding>
                        </Button.IsEnabled>
                    </Button>
                    <Button Content="{DynamicResource LogViewerView_ClearDisplay}" Command="{Binding ClearLogsCommand}" Margin="5,0"/>
                    <Button Content="{DynamicResource LogViewerView_ExportActivity}" Command="{Binding ExportLogsCommand}" Margin="5,0"/>
                    <Button Content="{DynamicResource LogViewerView_CleanupDiagnostics}" Command="{Binding CleanupOldLogsCommand}" Margin="5,0"/>
                    <Button Content="{DynamicResource LogViewerView_OpenFolder}" Command="{Binding OpenLogDirectoryCommand}" Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <!-- Log Entries List -->
            <ListView ItemsSource="{Binding LogEntries}"
                      SelectedItem="{Binding SelectedLogEntry}"
                      Style="{StaticResource LogListViewStyle}"
                      ItemContainerStyle="{StaticResource LogEntryStyle}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Item"
                      ScrollViewer.CanContentScroll="True">
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource LogGridViewHeaderStyle}">
                    <GridViewColumn Header="{DynamicResource LogViewerView_HeaderTime}" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FormattedTimestamp}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="{DynamicResource LogViewerView_HeaderStatus}" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}"
                                           Foreground="{Binding LevelColor}"
                                           Style="{StaticResource LogLevelTextStyle}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="{DynamicResource LogViewerView_HeaderCategory}" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Category}" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="{DynamicResource LogViewerView_HeaderMessage}" Width="500">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ShortMessage}" TextWrapping="NoWrap"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="{DynamicResource LogViewerView_HeaderDetails}" Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{DynamicResource ErrorTextBrush}" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDetails}" Value="True">
                                                    <Setter Property="Text" Value="!"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HasDetails}" Value="False">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="{DynamicResource LogViewerView_HeaderId}" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CorrelationId}" FontSize="10"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    </GridView>
                </ListView.View>

                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{DynamicResource LogViewerView_ContextMenuCopy}" Command="{Binding CopyLogEntryCommand}"
                                  CommandParameter="{Binding SelectedLogEntry}"/>
                        <Separator/>
                        <MenuItem Header="{DynamicResource LogViewerView_ContextMenuRefresh}" Command="{Binding RefreshLogsCommand}"/>
                    </ContextMenu>
                </ListView.ContextMenu>
            </ListView>

            <Border Padding="18"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LogEntries.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="{DynamicResource LogViewerView_NoEntries}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource LogViewerView_NoEntriesTip}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="360"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                      Background="{DynamicResource SurfaceStrokeColorDefaultBrush}" ResizeBehavior="PreviousAndNext"/>

        <!-- Activity Details -->
        <Border Grid.Row="4" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}" BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel Margin="16" DataContext="{Binding SelectedLogEntry}">
                    <TextBlock Text="{DynamicResource LogViewerView_DetailsTitle}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource LogViewerView_Timestamp}" FontWeight="SemiBold" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FormattedTimestamp}" Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource LogViewerView_Status}" FontWeight="SemiBold" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Status}"
                                   Foreground="{Binding LevelColor}" FontWeight="SemiBold" Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource LogViewerView_CategoryLabel}" FontWeight="SemiBold" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Category}" Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource LogViewerView_Message}" FontWeight="SemiBold" Margin="0,0,10,5" VerticalAlignment="Top"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Message, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap" Background="Transparent"
                                 BorderThickness="0" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource LogViewerView_Details}" FontWeight="SemiBold" Margin="0,0,10,5"
                                   VerticalAlignment="Top">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasDetails}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Details, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap" Background="Transparent"
                                 BorderThickness="0" Margin="0,0,0,10">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasDetails}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource LogViewerView_CorrelationId}" FontWeight="SemiBold" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding CorrelationId}"/>
                    </Grid>

                    <TextBlock Text="{DynamicResource LogViewerView_NoEntrySelected}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontStyle="Italic">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.SelectedLogEntry, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Status and Settings Panel -->
        <Border Grid.Row="5" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="10" BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status and Statistics -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="0,0,20,0" Opacity="{Binding StatusOpacity}"/>

                    <TextBlock Text="{DynamicResource LogViewerView_Files}" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LogStatistics.TotalLogFiles}" VerticalAlignment="Center" Margin="0,0,15,0"/>

                    <TextBlock Text="{DynamicResource LogViewerView_Size}" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                    <TextBlock VerticalAlignment="Center" Margin="0,0,15,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:F1} MB">
                                <Binding Path="LogStatistics.TotalLogSizeBytes" Converter="{x:Static local:BytesToMegabytesConverter.Instance}"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <ProgressBar IsIndeterminate="{Binding IsLoading}" Width="100" Height="16">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </StackPanel>

                <!-- Settings Panel -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <CheckBox Content="{DynamicResource LogViewerView_DebugDiagnostics}" IsChecked="{Binding EnableDebugLogging}"
                              VerticalAlignment="Center" Margin="0,0,15,0"/>

                    <TextBlock Text="{DynamicResource LogViewerView_MaxSize}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding MaxLogFileSizeMb}" Width="50" Margin="0,0,15,0"/>

                    <TextBlock Text="{DynamicResource LogViewerView_Retention}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding LogRetentionDays}" Width="50" Margin="0,0,15,0"/>

                    <Button Content="{DynamicResource LogViewerView_SaveSettings}" Command="{Binding SaveSettingsCommand}"
                            Padding="10,5" Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
