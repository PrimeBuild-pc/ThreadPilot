<UserControl x:Class="ThreadPilot.Views.PowerPlanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThreadPilot.Views"
             xmlns:helpers="clr-namespace:ThreadPilot.Helpers"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1200">
    
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Power Plans" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="Manage system power plans and import custom profiles" FontSize="14" Opacity="0.7"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- System Power Plans -->
            <GroupBox Grid.Column="0"
                    Header="Available Power Plans"
                    Margin="0,0,5,0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                            Command="{Binding LoadPowerPlansCommand}"
                            Content="Refresh Plans"
                            HorizontalAlignment="Right"
                            Padding="10,5"
                            Margin="0,0,0,12"
                            ToolTip="Refresh the list of available power plans"/>

                    <ui:ListView Grid.Row="1"
                                 ItemsSource="{Binding PowerPlans}"
                                 SelectedItem="{Binding SelectedPowerPlan}"
                                 Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                 BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        <ui:ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Name}"
                                            FontWeight="{Binding IsActive, Converter={StaticResource BoolToFontWeightConverter}}"/>
                                    <TextBlock Text="{Binding Guid}"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ui:ListView.ItemTemplate>
                    </ui:ListView>
                </Grid>
            </GroupBox>

            <!-- Custom Power Plans -->
            <GroupBox Grid.Column="1"
                    Header="Custom Power Plans"
                    Margin="5,0,0,0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                            Text="Available custom power plans:"
                            Margin="0,0,0,10"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                    <ui:ListView Grid.Row="1"
                                 ItemsSource="{Binding CustomPowerPlans}"
                                 SelectedItem="{Binding SelectedCustomPlan}"
                                 Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                 BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        <ui:ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Name}"/>
                                    <TextBlock Text="{Binding FilePath}"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ui:ListView.ItemTemplate>
                    </ui:ListView>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal" 
                    Margin="0,12,0,0">
            <Button Command="{Binding SetActivePlanCommand}"
                    Content="Set Active"
                    Padding="20,5"
                    Margin="0,0,10,0"
                    ToolTip="Activate the selected power plan"/>
            <Button Command="{Binding ImportCustomPlanCommand}"
                Content="Apply Selected Custom"
                    Padding="20,5"
                Margin="0,0,10,0"
                    ToolTip="Import the selected custom power plan into the system"/>
            <Button Command="{Binding AddCustomPlanFileCommand}"
                Content="Add .pow File"
                Padding="20,5"
                ToolTip="Add a new custom power plan file to the custom library"/>
        </StackPanel>
    </Grid>
</UserControl>
