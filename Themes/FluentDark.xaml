<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <!-- Theme values are self-contained so repeated Wpf.Ui theme replacement cannot leave stale card/control brushes. -->
    <Color x:Key="ApplicationBackgroundColor">#FF111318</Color>
    <Color x:Key="SolidBackgroundFillColorBase">#FF0F1115</Color>
    <Color x:Key="CardBackgroundFillColorDefault">#FF1E2128</Color>
    <Color x:Key="CardBackgroundFillColorSecondary">#FF252933</Color>
    <Color x:Key="ControlFillColorDefault">#FF242832</Color>
    <Color x:Key="ControlFillColorSecondary">#FF2C313C</Color>
    <Color x:Key="ControlFillColorTertiary">#FF373D49</Color>
    <Color x:Key="ControlFillColorDisabled">#FF1B1F27</Color>
    <Color x:Key="ControlStrokeColorDefault">#FF3D4450</Color>
    <Color x:Key="ControlStrokeColorSecondary">#FF303743</Color>
    <Color x:Key="SurfaceStrokeColorDefault">#FF3D4450</Color>
    <Color x:Key="TextFillColorPrimary">#FFF4F7FB</Color>
    <Color x:Key="TextFillColorSecondary">#FFC1C8D3</Color>
    <Color x:Key="TextFillColorDisabled">#FF737B88</Color>
    <Color x:Key="SystemAccentColorPrimary">#FF5FA8FF</Color>
    <Color x:Key="SystemAccentColorSecondary">#FF3E84D8</Color>
    <Color x:Key="AccentFillColorDefault">#FF3E84D8</Color>
    <Color x:Key="TextOnAccentFillColorPrimary">#FFFFFFFF</Color>

    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource ApplicationBackgroundColor}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource SolidBackgroundFillColorBase}"/>
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource CardBackgroundFillColorDefault}"/>
    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="{StaticResource CardBackgroundFillColorSecondary}"/>
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource ControlFillColorDefault}"/>
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource ControlFillColorSecondary}"/>
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource ControlFillColorTertiary}"/>
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{StaticResource ControlFillColorDisabled}"/>
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource ControlStrokeColorDefault}"/>
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource ControlStrokeColorSecondary}"/>
    <SolidColorBrush x:Key="SurfaceStrokeColorDefaultBrush" Color="{StaticResource SurfaceStrokeColorDefault}"/>
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource TextFillColorPrimary}"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource TextFillColorSecondary}"/>
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource TextFillColorDisabled}"/>
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource AccentFillColorDefault}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="{StaticResource TextOnAccentFillColorPrimary}"/>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource ApplicationBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ControlFillColorDefault}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource CardBackgroundFillColorSecondary}"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource ControlFillColorSecondary}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextFillColorPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextFillColorSecondary}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextFillColorDisabled}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource SystemAccentColorPrimary}"/>
    <SolidColorBrush x:Key="AccentAltBrush" Color="{StaticResource SystemAccentColorSecondary}"/>

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ControlStrokeColorDefault}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource ControlStrokeColorSecondary}"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="#99020617"/>
    <SolidColorBrush x:Key="SpinnerTrackBrush" Color="{StaticResource ControlStrokeColorDefault}"/>

    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource ControlFillColorDefault}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource ControlStrokeColorDefault}"/>
    <SolidColorBrush x:Key="InputHoverBorderBrush" Color="{StaticResource ControlStrokeColorSecondary}"/>
    <SolidColorBrush x:Key="InputDisabledBackgroundBrush" Color="{StaticResource ControlFillColorDisabled}"/>
    
    <!-- State Colors (system-derived, soft contrast) -->
    <SolidColorBrush x:Key="InfoBackgroundBrush" Color="{StaticResource SystemAccentColorPrimary}" Opacity="0.14"/>
    <SolidColorBrush x:Key="InfoBorderBrush" Color="{StaticResource SystemAccentColorPrimary}" Opacity="0.28"/>
    <SolidColorBrush x:Key="InfoTextBrush" Color="{StaticResource TextFillColorPrimary}"/>

    <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="{StaticResource SystemAccentColorPrimary}" Opacity="0.12"/>
    <SolidColorBrush x:Key="SuccessBorderBrush" Color="{StaticResource SystemAccentColorPrimary}" Opacity="0.26"/>
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource TextFillColorPrimary}"/>

    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="{StaticResource SystemAccentColorPrimary}" Opacity="0.12"/>
    <SolidColorBrush x:Key="WarningBorderBrush" Color="{StaticResource SystemAccentColorPrimary}" Opacity="0.26"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource TextFillColorPrimary}"/>

    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="{StaticResource SystemAccentColorPrimary}" Opacity="0.12"/>
    <SolidColorBrush x:Key="ErrorBorderBrush" Color="{StaticResource SystemAccentColorPrimary}" Opacity="0.26"/>
    <SolidColorBrush x:Key="ErrorTextBrush" Color="{StaticResource TextFillColorPrimary}"/>

    <SolidColorBrush x:Key="SoftSelectionBackgroundBrush" Color="{StaticResource SystemAccentColorPrimary}" Opacity="0.16"/>
    <SolidColorBrush x:Key="SoftSelectionBorderBrush" Color="{StaticResource SystemAccentColorPrimary}" Opacity="0.30"/>

    <!-- System Colors overrides -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{StaticResource ApplicationBackgroundColor}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{StaticResource TextFillColorPrimary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="{StaticResource ControlFillColorDefault}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{StaticResource TextFillColorPrimary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="{StaticResource ControlFillColorSecondary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="{StaticResource ControlFillColorTertiary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="{StaticResource ControlStrokeColorDefault}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="{StaticResource ControlStrokeColorSecondary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="{StaticResource TextFillColorDisabled}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource SystemAccentColorPrimary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{StaticResource TextFillColorPrimary}"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
    </Style>

    <Style TargetType="UserControl">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
    </Style>

    <Style TargetType="Control">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
    </Style>

    <Style TargetType="Grid">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style TargetType="Border">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <DockPanel LastChildFill="True">
                            <ContentPresenter ContentSource="Header"
                                              DockPanel.Dock="Top"
                                              Margin="0,0,0,6"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontWeight="SemiBold"/>
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Preserved custom layouts/templates untouched -->
    <!-- Removed native implicit styles (TabControl, ComboBox, etc) to allow Wpf.Ui to style them fully -->

    <!-- Preserved explicit font settings -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="TextElement">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
    </Style>
</ResourceDictionary>
