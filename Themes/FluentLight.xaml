<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <!-- Light Theme Colors mapped to Wpf.Ui equivalents where matching -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{DynamicResource ApplicationBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource ControlFillColorDefault}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource CardBackgroundFillColorSecondary}"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{DynamicResource ControlFillColorSecondary}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextFillColorPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextFillColorSecondary}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{DynamicResource TextFillColorDisabled}"/>
    
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource SystemAccentColorPrimary}"/>
    <SolidColorBrush x:Key="AccentAltBrush" Color="{DynamicResource SystemAccentColorSecondary}"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource ControlStrokeColorDefault}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{DynamicResource ControlStrokeColorSecondary}"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="#6618181B"/>
    <SolidColorBrush x:Key="SpinnerTrackBrush" Color="{DynamicResource ControlStrokeColorDefault}"/>
    
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{DynamicResource ControlFillColorDefault}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{DynamicResource ControlStrokeColorDefault}"/>
    <SolidColorBrush x:Key="InputHoverBorderBrush" Color="{DynamicResource ControlStrokeColorSecondary}"/>
    <SolidColorBrush x:Key="InputDisabledBackgroundBrush" Color="{DynamicResource ControlFillColorDisabled}"/>
    
    <!-- State Colors (system-derived, soft contrast) -->
    <SolidColorBrush x:Key="InfoBackgroundBrush" Color="{DynamicResource SystemAccentColorPrimary}" Opacity="0.12"/>
    <SolidColorBrush x:Key="InfoBorderBrush" Color="{DynamicResource SystemAccentColorPrimary}" Opacity="0.24"/>
    <SolidColorBrush x:Key="InfoTextBrush" Color="{DynamicResource TextFillColorPrimary}"/>

    <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="{DynamicResource SystemAccentColorPrimary}" Opacity="0.10"/>
    <SolidColorBrush x:Key="SuccessBorderBrush" Color="{DynamicResource SystemAccentColorPrimary}" Opacity="0.22"/>
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{DynamicResource TextFillColorPrimary}"/>

    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="{DynamicResource SystemAccentColorPrimary}" Opacity="0.10"/>
    <SolidColorBrush x:Key="WarningBorderBrush" Color="{DynamicResource SystemAccentColorPrimary}" Opacity="0.22"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="{DynamicResource TextFillColorPrimary}"/>

    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="{DynamicResource SystemAccentColorPrimary}" Opacity="0.10"/>
    <SolidColorBrush x:Key="ErrorBorderBrush" Color="{DynamicResource SystemAccentColorPrimary}" Opacity="0.22"/>
    <SolidColorBrush x:Key="ErrorTextBrush" Color="{DynamicResource TextFillColorPrimary}"/>

    <SolidColorBrush x:Key="SoftSelectionBackgroundBrush" Color="{DynamicResource SystemAccentColorPrimary}" Opacity="0.12"/>
    <SolidColorBrush x:Key="SoftSelectionBorderBrush" Color="{DynamicResource SystemAccentColorPrimary}" Opacity="0.24"/>

    <!-- System Colors overrides -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{DynamicResource ApplicationBackgroundColor}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{DynamicResource TextFillColorPrimary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="{DynamicResource ControlFillColorDefault}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{DynamicResource TextFillColorPrimary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="{DynamicResource ControlFillColorSecondary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="{DynamicResource ControlFillColorTertiary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="{DynamicResource ControlStrokeColorDefault}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="{DynamicResource ControlStrokeColorSecondary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="{DynamicResource TextFillColorDisabled}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{DynamicResource SystemAccentColorPrimary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{DynamicResource TextFillColorPrimary}"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
    </Style>

    <Style TargetType="UserControl">
        <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
    </Style>

    <Style TargetType="Control">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
    </Style>

    <Style TargetType="Grid">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <DockPanel LastChildFill="True">
                            <ContentPresenter ContentSource="Header"
                                              DockPanel.Dock="Top"
                                              Margin="0,0,0,6"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontWeight="SemiBold"/>
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Preserved custom layouts/templates untouched -->
    <!-- Removed native implicit styles to allow Wpf.Ui to style them fully -->

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="TextElement">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
    </Style>
</ResourceDictionary>
